# SC2 build artifacts — NEVER commit these. They are fetched/generated by
# build/fetch-artifacts.sh + build/build-bundle.sh (see docs/BUILDING.md).
# The source of truth for what they contain is build.conf, not git.

# Final shippable bundles
/dist/

# Offline RPM closures (fetched per RHEL major)
/rpms/el*/*.rpm
/rpms/el*/repodata/

# Managed-app image archives (docker/podman save output)
/images/*.tgz
/images/*.tar
/images/*.tar.gz

# Pre-loaded standalone container archives (containers/README.md is kept)
/containers/*.tgz
/containers/*.tar
/containers/*.tar.gz

# Large binary artifact payloads fetched for bundle.conf 'copy' directives.
# The small text sample under artifacts/app/ IS tracked; drop fetched binaries
# under artifacts/fetched/ so they stay out of git.
/artifacts/fetched/

# Generated at package time
/sha256sums
